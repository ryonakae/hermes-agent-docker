# タイムゾーン
TZ=Asia/Tokyo

# OpenRouter API キー
OPENROUTER_API_KEY=

# Slack Bot User OAuth Token (xoxb-)
SLACK_BOT_TOKEN=

# Slack App-Level Token for Socket Mode (xapp-)
SLACK_APP_TOKEN=

# Slack 許可ユーザー（カンマ区切りの Member ID）
SLACK_ALLOWED_USERS=

# Slack ホームチャンネル（任意）
SLACK_HOME_CHANNEL=
SLACK_HOME_CHANNEL_NAME=

# gws 用の認証 JSON（任意）
# 例: /opt/data/secrets/gws-credentials.json
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=
